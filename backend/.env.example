# Copy this file to backend/.env and insert your Twelve Data API key.
# Get a free key at https://twelvedata.com/pricing
TWELVE_DATA_API_KEY=your_key_here

# Gemini API key for speech-to-text (voice commands). Get one at
# https://aistudio.google.com/apikey — used by backend/services/stt.py
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Spotify Web API (for song search & play) ────────────────────────────────
# Create a Spotify Developer App at: https://developer.spotify.com/dashboard
# Add redirect URI: http://localhost:8888/callback
# Then run:  python backend/spotify_auth_setup.py
# That script will auto-fill SPOTIFY_REFRESH_TOKEN below.
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REFRESH_TOKEN=generated_by_spotify_auth_setup_py

# ── Spotify Playlist URIs (optional overrides) ───────────────────────────────
# SPOTIFY_PLAYLIST_HINDI=spotify:playlist:4SuEAsJ6ulS62RYJk88Sap
# SPOTIFY_PLAYLIST_ENGLISH=spotify:playlist:2CCKzQqgsc50gtJeYDonJh
# SPOTIFY_PLAYLIST_KRISHNA=spotify:playlist:3Fd9z849SrTBEtHDTgQvXo
